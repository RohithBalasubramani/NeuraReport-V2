{
  "name": "neurareport-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist node_modules/.vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node ./scripts/run-vitest.mjs",
    "test:ui": "playwright test --grep @ui",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "shots:update": "playwright test --grep @visual --update-snapshots",
    "lint:theme": "node ./scripts/lint-theme.mjs",
    "size": "npm run build && size-limit",
    "size:why": "npm run build && size-limit --why",
    "openapi:export": "python ../scripts/export_openapi.py --output ../docs/openapi.json",
    "openapi:generate": "npm run openapi:export && openapi-generator-cli generate -i ../docs/openapi.json -g typescript-axios -o src/api/generated --skip-validate-spec --additional-properties=supportsES6=true,withSeparateModelsAndApi=true,apiPackage=api,modelPackage=models,useSingleRequestParameter=true,enumPropertyNaming=original"
  },
