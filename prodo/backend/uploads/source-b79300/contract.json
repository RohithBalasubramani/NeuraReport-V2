  "literals": {},
  "notes": "The 'row_sl_no' is a generated index within the batch context. The 'batch_num' and 'batch_no' are mapped to the recipe ID to group rows. The reshape rule handles the 12 bins.",
  "_schema_version": "2.2",
  "fields": {
    "batch_num": {
      "source": "recipes.id",
      "computed": "ROW_NUMBER"
    },
    "row_ach_wt_kg": {
      "format": "number(2)"
    },
    "to_date": {
      "source": "recipes.end_time",
      "format": "number(2)"
    },
    "end_time": {
