    },
    "row_sl_no": {
      "computed": "{\"op\": \"expression\", \"expr\": \"ROW_NUMBER_WITHIN_BATCH\"}"
    },
    "start_time": {
      "source": "recipes.start_time"
    },
    "row_error_pct": {
      "format": "percent(2)",
      "computed": "{\"op\": \"multiply\", \"left\": {\"op\": \"divide\", \"numerator\": {\"op\": \"subtract\", \"left\": \"row_ach_wt_kg\", \"right\": \"row_set_wt_kg\"}, \"denominator\": \"row_set_wt_kg\"}, \"right\": 100}"
    },
    "batch_no": {
      "source": "recipes.id",
      "computed": "ROW_NUMBER"
    },
    "total_error_pct": {
      "format": "percent(2)",
      "aggregate": "EXPRESSION",
      "computed": "AVG(row_error_pct)"
    },
    "row_error_kg": {
      "format": "number(2)",
      "computed": "{\"op\": \"subtract\", \"left\": \"row_ach_wt_kg\", \"right\": \"row_set_wt_kg\"}"
    },
    "print_date": {
      "computed": "{\"op\": \"expression\", \"expr\": \"CURRENT_DATE\"}"
    },
    "total_ach_wt_kg": {
