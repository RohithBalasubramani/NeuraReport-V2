  },
  "filters": {
    "optional": {
      "date_from": "recipes.start_time",
      "date_to": "recipes.end_time"
    }
  },
  "reshape_rules": [
    {
      "purpose": "Melt 12 bin columns into long format rows",
      "strategy": "MELT",
      "columns": [
        {
          "as": "row_sl_no",
          "from": [
            "INDEX"
          ]
        },
        {
          "as": "row_ach_wt_kg",
          "from": [
            "recipes.bin1_act",
            "recipes.bin2_act",
            "recipes.bin3_act",
            "recipes.bin4_act",
            "recipes.bin5_act",
            "recipes.bin6_act",
            "recipes.bin7_act",
            "recipes.bin8_act",
            "recipes.bin9_act",
            "recipes.bin10_act",
            "recipes.bin11_act",
            "recipes.bin12_act"
          ]
        },
        {
          "as": "row_material_name",
          "from": [
            "recipes.bin1_content",
            "recipes.bin2_content",
            "recipes.bin3_content",
            "recipes.bin4_content",
            "recipes.bin5_content",
            "recipes.bin6_content",
            "recipes.bin7_content",
            "recipes.bin8_content",
            "recipes.bin9_content",
            "recipes.bin10_content",
            "recipes.bin11_content",
            "recipes.bin12_content"
          ]
        },
        {
          "as": "row_set_wt_kg",
          "from": [
            "recipes.bin1_sp",
            "recipes.bin2_sp",
            "recipes.bin3_sp",
            "recipes.bin4_sp",
            "recipes.bin5_sp",
            "recipes.bin6_sp",
            "recipes.bin7_sp",
            "recipes.bin8_sp",
            "recipes.bin9_sp",
            "recipes.bin10_sp",
            "recipes.bin11_sp",
            "recipes.bin12_sp"
          ]
        }
      ],
      "order_by": []
    }
  ],
  "row_computed": {
    "print_date": {
      "op": "expression",
      "expr": "CURRENT_DATE"
    },
    "row_error_kg": {
      "op": "subtract",
      "left": "row_ach_wt_kg",
      "right": "row_set_wt_kg"
    },
    "row_error_pct": {
      "op": "multiply",
      "left": {
        "op": "divide",
        "numerator": {
          "op": "subtract",
          "left": "row_ach_wt_kg",
          "right": "row_set_wt_kg"
        },
        "denominator": "row_set_wt_kg"
      },
      "right": 100
    },
    "row_sl_no": {
      "op": "expression",
      "expr": "ROW_NUMBER_WITHIN_BATCH"
    }
  },
  "totals_math": {
    "total_ach_wt_kg": {
      "op": "expression",
      "expr": "SUM(row_ach_wt_kg)"
    },
    "total_error_kg": {
      "op": "expression",
      "expr": "SUM(row_error_kg)"
    },
    "total_error_pct": {
      "op": "expression",
      "expr": "AVG(row_error_pct)"
    },
    "total_set_wt_kg": {
      "op": "expression",
      "expr": "SUM(row_set_wt_kg)"
    }
  },
  "totals": {
    "total_ach_wt_kg": {
      "op": "expression",
      "expr": "SUM(row_ach_wt_kg)"
    },
    "total_error_kg": {
      "op": "expression",
      "expr": "SUM(row_error_kg)"
    },
    "total_error_pct": {
      "op": "expression",
      "expr": "AVG(row_error_pct)"
    },
    "total_set_wt_kg": {
      "op": "expression",
      "expr": "SUM(row_set_wt_kg)"
    }
  },
  "formatters": {
    "row_set_wt_kg": "number(2)",
    "row_ach_wt_kg": "number(2)",
    "row_error_kg": "number(2)",
    "row_error_pct": "percent(2)",
    "total_set_wt_kg": "number(2)",
    "total_ach_wt_kg": "number(2)",
    "total_error_kg": "number(2)",
    "total_error_pct": "percent(2)",
    "from_date": "number(2)",
    "to_date": "number(2)"
  },
  "order_by": {
    "rows": [
      "recipes.id ASC",
      "row_sl_no ASC"
    ]
  },
  "header_tokens": [
    "plant_name",
    "location",
    "print_date",
    "from_date",
    "to_date",
    "batch_no",
    "report_title",
