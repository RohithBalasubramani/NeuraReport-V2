{"event": "chat_complete", "action": "hydrate", "pipeline_state": "ready", "session_id": "f01-real", "connection_id": "01a59e23-ac90-4e61-916f-4644a16a4b30", "action_result": {"template": {"html": "\n\n\n<meta charset=\"UTF-8\">\n<title>Sample Invoice Template</title>\n<style>\n    :root {\n        --primary-green: #52b848; /* Adjusted to match reference lime green */\n        --text-dark: #333;\n        --text-blue: #2c4d82; /* Dark blue for headers */\n        --border-color: #ccc;\n        --font-family: 'Arial', 'Helvetica', sans-serif;\n        --page-width: 210mm;\n        --page-padding: 20mm;\n    }\n\n    body {\n        font-family: var(--font-family);\n        margin: 0;\n        padding: 0;\n        background-color: #fff;\n        color: var(--text-dark);\n        font-size: 12pt; /* Standard print size */\n        line-height: 1.4;\n        -webkit-print-color-adjust: exact;\n        print-color-adjust: exact;\n    }\n\n    .page-container {\n        width: var(--page-width);\n        margin: 0 auto;\n        padding: var(--page-padding);\n        box-sizing: border-box;\n        position: relative;\n    }\n\n    /* Header */\n    .header-bar {\n        background-color: var(--primary-green);\n        height: 90px;\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        padding: 0 25px;\n        margin-bottom: 35px;\n    }\n\n    .logo-placeholder {\n        width: 85px;\n        height: 85px;\n        background-color: #777;\n        border-radius: 50%;\n        color: white;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-weight: bold;\n        font-size: 18px;\n        letter-spacing: 1px;\n    }\n\n    .header-title {\n        color: white;\n        font-size: 24px;\n        font-weight: bold;\n    }\n\n    /* Top Info Layout */\n    .top-info {\n        display: flex;\n        justify-content: space-between;\n        margin-bottom: 40px;\n    }\n\n    .left-column {\n        width: 55%;\n    }\n\n    .right-column {\n        width: 40%;\n        text-align: right;\n    }\n\n    .section-header {\n        color: var(--text-blue);\n        font-weight: bold;\n        font-size: 13pt;\n        margin-bottom: 6px;\n        display: block;\n    }\n\n    .company-info, .bill-to-info {\n        margin-bottom: 25px;\n    }\n\n    .meta-row {\n        display: flex;\n        justify-content: flex-end;\n        align-items: baseline;\n        margin-bottom: 12px;\n    }\n\n    .meta-label {\n        color: var(--text-blue);\n        font-weight: bold;\n        margin-right: 20px;\n        text-align: right;\n    }\n\n    .meta-value {\n        color: var(--text-dark);\n        font-weight: normal;\n    }\n\n    .payment-terms {\n        margin-top: 15px;\n        font-style: italic;\n        color: var(--text-dark);\n    }\n\n    /* Table */\n    .invoice-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 10px;\n        table-layout: fixed;\n        border: 1px solid var(--border-color);\n    }\n\n    .invoice-table th {\n        background-color: var(--primary-green);\n        color: white;\n        padding: 10px 5px;\n        text-align: center;\n        font-weight: bold;\n        font-size: 12pt;\n        border: 1px solid var(--primary-green);\n        text-transform: uppercase;\n    }\n\n    .invoice-table td {\n        border: 1px solid var(--border-color);\n        padding: 8px 5px;\n        vertical-align: middle;\n        font-size: 11pt;\n    }\n\n    .col-desc {\n        width: 45%;\n        text-align: left;\n    }\n\n    .col-qty {\n        width: 12%;\n        text-align: right;\n    }\n\n    .col-price {\n        width: 23%;\n        text-align: right;\n    }\n\n    .col-total {\n        width: 20%;\n        text-align: right;\n    }\n\n    .row-stripe {\n        background-color: #f5f5f5;\n    }\n\n    /* Totals &amp; Remarks Section */\n    .totals-container {\n        display: flex;\n        justify-content: space-between;\n        margin-top: 0;\n        align-items: flex-start;\n    }\n\n    .remarks-box {\n        width: 55%;\n        padding-top: 5px;\n        font-size: 11pt;\n    }\n\n    .totals-box {\n        width: 40%;\n        border: 1px solid var(--border-color);\n    }\n\n    .total-row {\n        display: flex;\n        justify-content: space-between;\n        padding: 6px 10px;\n        border-bottom: 1px solid var(--border-color);\n        font-size: 11pt;\n    }\n\n    .total-row:last-child {\n        border-bottom: none;\n    }\n\n    .total-label {\n        text-align: right;\n        font-weight: bold;\n        color: #444;\n        padding-right: 10px;\n    }\n\n    .total-value {\n        text-align: right;\n        font-variant-numeric: tabular-nums;\n    }\n\n    .balance-due-row {\n        background-color: var(--primary-green);\n        color: white;\n        font-weight: bold;\n        font-size: 13pt;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        padding: 10px 15px;\n        border-top: 2px solid var(--border-color);\n    }\n\n    .balance-due-label {\n        color: white;\n        text-align: right;\n        flex: 1;\n    }\n\n    .balance-due-value {\n        color: white;\n        text-align: right;\n        font-size: 14pt;\n        padding-left: 15px;\n        font-variant-numeric: tabular-nums;\n    }\n\n    /* Footer Area */\n    .footer-area {\n        margin-top: 60px;\n        position: relative;\n        height: 180px;\n    }\n\n    .payment-instructions {\n        margin-bottom: 30px;\n        font-size: 11pt;\n        max-width: 40%;\n    }\n\n    .signatures {\n        display: flex;\n        justify-content: space-between;\n        margin-bottom: 40px;\n        color: #555;\n        font-size: 12pt;\n    }\n\n    .footer-content {\n        display: flex;\n        justify-content: space-between;\n        align-items: flex