}\n\n    .company-details, .bill-to-details {\n        width: 45%;\n    }\n\n    .invoice-meta {\n        width: 50%;\n        text-align: right;\n    }\n\n    .label {\n        font-weight: bold;\n        color: #2c3e50;\n        margin-bottom: 4px;\n        display: block;\n    }\n\n    .value {\n        margin-bottom: 8px;\n        font-size: 14px;\n    }\n\n    .bill-to-section {\n        margin-top: 30px;\n    }\n\n    /* Table Styling */\n    .table-container {\n        width: 100%;\n        margin-bottom: 20px;\n        border-collapse: collapse;\n        border: 1px solid var(--border-color);\n        table-layout: fixed;\n    }\n\n    .table-header {\n        background-color: var(--primary-green);\n        color: white;\n        text-transform: uppercase;\n        font-weight: bold;\n        padding: 8px;\n        text-align: center;\n        font-family: var(--header-font);\n    }\n\n    .table-body td {\n        border: 1px solid var(--border-color);\n        padding: 6px 8px;\n        vertical-align: middle;\n    }\n\n    .col-desc { width: var(--col-desc); }\n    .col-qty { width: var(--col-qty); text-align: center; }\n    .col-price { width: var(--col-price); text-align: right; padding-right: 10px; }\n    .col-total { width: var(--col-total); text-align: right; padding-right: 10px; }\n\n    .table-body tr:nth-child(even) {\n        background-color: #f9f9f9;\n    }\n\n    /* Totals Section */\n    .totals-container {\n        display: flex;\n        justify-content: flex-end;\n        margin-top: 0;\n    }\n\n    .totals-table {\n        border-collapse: collapse;\n        width: 350px;\n        border: 1px solid var(--border-color);\n    }\n\n    .totals-table td {\n        border: 1px solid var(--border-color);\n        padding: 6px 10px;\n        font-size: 14px;\n    }\n\n    .totals-label {\n        text-align: right;\n        font-weight: bold;\n        color: #444;\n        width: 70%;\n    }\n\n    .totals-value {\n        text-align: right;\n